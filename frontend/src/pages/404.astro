---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Not Found" noindex>
  <div class="mx-auto max-w-3xl px-6 py-48 text-center">
    <p class="text-8xl font-bold bg-gradient-to-r from-gradient-start to-gradient-end bg-clip-text text-transparent">
      404
    </p>
    <p class="mt-6 text-xl text-muted">This page doesn't exist. Maybe it was dispatched elsewhere.</p>
    <a href="/" class="mt-10 inline-block rounded-full bg-gradient-to-r from-gradient-start to-gradient-end px-6 py-2.5 text-sm font-medium text-white hover:opacity-90 transition-opacity">
      Back to home
    </a>
  </div>
</Layout>
