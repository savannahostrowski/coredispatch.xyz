---
import type { IssueQuote } from "../lib/types";

interface Props {
  quote: IssueQuote;
}

const { quote } = Astro.props;

// Normalize legacy single quotes and multi-speaker exchanges into one shape.
// Fall back to the legacy fields only when `lines` is absent or empty, matching
// the backend RSS renderer.
const lines =
  quote.lines && quote.lines.length > 0
    ? quote.lines
    : quote.text
      ? [{ text: quote.text, author: quote.author ?? "", url: quote.url }]
      : [];
---

<section class="mb-10 scroll-mt-16" id="one-more-thing">
  <div class="mb-2 pb-2 border-b border-border">
    <div class="flex items-center gap-2.5">
      <span class="text-lg" aria-hidden="true">{"\u{1F4AC}"}</span>
      <h2 class="text-base font-semibold">One More Thing...</h2>
    </div>
    <p class="mt-1 text-xs text-muted">Your favourite funny, informative, or mass-reply-inducing words.</p>
  </div>
  <blockquote class="border-l-3 border-accent/40 pl-4 py-2 space-y-3">
    {lines.map((line) => (
      <div>
        <p class="text-[15px] italic leading-relaxed text-foreground/90">{line.text}</p>
        <p class="mt-1 text-sm text-muted">
          {"— "}
          {line.url ? (
            <a href={line.url} class="text-accent hover:text-accent-hover transition-colors">{line.author}</a>
          ) : (
            line.author
          )}
        </p>
      </div>
    ))}
  </blockquote>
  <p class="mt-3 text-xs text-muted">
    Have a great quote?{" "}
    <a href="/submit"
      class="text-accent hover:text-accent-hover transition-colors">
      Submit one for next edition</a>.
  </p>
</section>
